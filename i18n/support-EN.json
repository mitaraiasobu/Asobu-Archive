  "support": {
    "title": "",
    "bodyHtml": "<div class=\"support-card support-card--wide\">\n  <div class=\"support-top-stripe\"></div>\n  <div class=\"support-inner\">\n\n    <!-- ── Header ── -->\n    <div class=\"support-header\">\n      <div class=\"support-main-title\">Ways to Support<br></div><div class=\"support-sub-title\">Aim to complete them all, starting from the top!</div> <div class=\"support-deco-line\">♡ ♡ ♡</div><span class=\"support-accent\">If you're a Jyumyou, it's only natural...right?</span>\n    </div>\n\n    <!-- ── Spread / Tech Section ── -->\n    <div class=\"support-accordion-wrap open\" id=\"acc-spread\">\n      <div class=\"support-accordion-header\" onclick=\"toggleAcc('acc-spread')\">\n        <div class=\"support-sec-head\"><span class=\"support-sec-icon\">⋈</span> Support with sharing & skills</div>\n        <span class=\"support-accordion-arrow\">▼</span>\n      </div>\n      <div class=\"support-accordion-body\">\n\n        <!-- ── Clip Request Section ── -->\n        <div class=\"support-clip-request\">\n          <div class=\"support-clip-request__img-wrap\">\n            <img src=\"./assets/切り抜きリクエスト.png\" alt=\"Clip Request\" class=\"support-clip-request__img\" />\n          </div>\n          <div class=\"support-clip-request__body\">\n            <div class=\"support-clip-request__title\">Tell me which scenes you'd like turned into clips!</div>\n            <div class=\"support-clip-request__desc\">Send me the livestream link and timestamp (e.g. 1:20:14) of your favorite moment, and a clip video might be created! It's really hard to find scenes on my own, so your help is greatly appreciated!</div>\n            <a class=\"support-clip-request__btn\" href=\"https://marshmallow-qa.com/g2t47f2przg3nzd\" target=\"_blank\" rel=\"noopener\">🎬 Request a clip scene</a>\n          </div>\n        </div>\n\n        <div class=\"support-spread-list\">\n\n      <div class=\"support-spread-item\">\n        <div class=\"support-pink-dot\"></div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">Like & Share & Hype</div>\n          <div class=\"support-inote\">Please spread YouTube videos, livestreams, and X posts 🤍<br>Pressing Share → Copy helps boost the recommendation algorithm!</div>\n        </div>\n      </div>\n\n      <div class=\"support-spread-item\">\n        <div class=\"support-pink-dot\"></div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">Join a Contest</div>\n          <div class=\"support-inote\">Participate in coloring or illustration contests and hype things up together!</div>\n        </div>\n        <a class=\"support-item-arrow\" href=\"#contest\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='contest'\">➡</a>\n      </div>\n\n      <div class=\"support-spread-item\">\n        <div class=\"support-pink-dot\"></div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">Make a Clip Video</div>\n          <div class=\"support-inote\">Send me the finished clip! I'll post it on my channel!</div>\n        </div>\n      </div>\n\n      </div><!-- /spread-list -->\n      </div><!-- /accordion-body -->\n    </div><!-- /acc-spread -->\n\n    <!-- ── Priority list ── -->\n    <div class=\"support-accordion-wrap open\" id=\"acc-money\">\n      <div class=\"support-accordion-header\" onclick=\"toggleAcc('acc-money')\">\n        <div class=\"support-sec-head\"><span class=\"support-sec-icon\">⋈</span> Support for adults ♡</div>\n        <span class=\"support-accordion-arrow\">▼</span>\n      </div>\n      <div class=\"support-accordion-body\">\n        <div style=\"font-size:1.4em;font-weight:900;letter-spacing:.02em;padding:10px 16px 10px 20px;color:#ffffff;border-left:3px solid #ff79b0;margin:0 0 12px 0;\">Asobu's Happiness Ranking</div>\n        <div class=\"support-list\">\n      <div class=\"support-item-row\">\n      <div class=\"support-item support-top\">\n        <div class=\"support-nbubble\">1</div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">Membership</div>\n          <div class=\"support-inote\">Monthly renewals make me the happiest! Exclusive merch gifts too~</div>\n        </div>\n        <div class=\"support-iright\">¥490~/mo</div>\n      </div>\n      <a class=\"support-item-arrow\" href=\"#membership\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='membership'\">➡</a>\n      </div>\n      <div class=\"support-item-row\">\n      <div class=\"support-item\">\n        <div class=\"support-nbubble\">2</div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">Buy Merch</div>\n          <div class=\"support-inote\">Just seeing me on screen isn't enough, is it?</div>\n        </div>\n        <div class=\"support-iright\">¥750~</div>\n      </div>\n      <a class=\"support-item-arrow\" href=\"#goods\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='goods'\">➡</a>\n      </div>\n\n        <div class=\"support-item-row\">\n        <div class=\"support-item\">\n          <div class=\"support-nbubble\">3</div>\n          <div class=\"support-ibody\">\n            <div class=\"support-iname\">Super Chat / Member Gifting</div>\n            <div class=\"support-inote\">Give me some during livestreams anytime 🖤 ¥1,000/day is a must!</div>\n          </div>\n          <span class=\"support-iright\">¥100~</span>\n        </div>\n        <a class=\"support-item-arrow\" href=\"https://www.youtube.com/@MitaraiAsobu\" target=\"_blank\" rel=\"noopener\">➡</a>\n        </div>\n      </div>\n    <div class=\"sp-wish\" style=\"margin:24px 0;\">\n      <div class=\"sp-wish__body\">\n        <img class=\"sp-wish__icon\" src=\"./mita/money.png\" alt=\"Mitarai Asobu\">\n        <div class=\"sp-wish__bubble-wrap\">\n          <div class=\"sp-wish__bubble\">Offering! Offering~!</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- ── Crowdfunding Note ── -->\n    <div class=\"support-sec-head\"><span class=\"support-sec-icon\">⋈</span> About Crowdfunding</div>\n\n    <div class=\"support-goods-box\">\n      <div class=\"support-goods-icon\">💰</div>\n      <div class=\"support-goods-body\">\n        <div class=\"support-goods-title\">Every form of support counts toward the crowdfunding total! Check the crowdfunding page for details.</div>\n        <a class=\"support-clip-request__btn\" href=\"#crowdfunding\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='crowdfunding'\" style=\"margin-top:14px;display:inline-flex;\">🎗 View Crowdfunding Page</a>\n      </div>\n    </div>\n\n      </div><!-- /accordion-body -->\n    </div><!-- /acc-money -->\n\n    <!-- ── Footer ── -->\n    <div class=\"support-footer\">\n      <div class=\"support-footer-hearts\">♡ ♡ ♡</div>\n      <div class=\"support-footer-msg\">More fun days ahead with you cheering me on</div>\n      <div class=\"support-footer-name\">Mitarai Asobu</div>\n      <div class=\"support-footer-roman\">Mitarai Asobu</div>\n    </div>\n\n  </div>\n</div>"
  }
}
