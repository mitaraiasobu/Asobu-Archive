  "about": {
    "title": "About",
    "bodyHtml": "<div class=\"about-profile-wrap\">\n\n  <!-- ===== Character Art + Name Area ===== -->\n  <div class=\"about-stand-col\">\n    <div class=\"about-stand-img-wrap\">\n      <img src=\"./assets/default-2.png\" alt=\"Mitarai Asobu\" class=\"about-stand-img\" />\n    </div>\n  </div>\n\n  <!-- ===== Profile Info Area ===== -->\n  <div class=\"about-info-col\">\n\n    <div class=\"about-name-block\">\n      <h1 class=\"about-name-ja\">御手洗 遊</h1>\n      <p class=\"about-name-roman\">Mitarai Asobu</p>\n </div>\n\n    <div class=\"about-catch\">I can be a bit mischievous and pretty playful...<br>but let's get along, okay?</div>\n\n    <div class=\"about-stats\">\n      <div class=\"about-stat-row\"><span class=\"about-stat-icon\">🦝</span><span class=\"about-stat-label\">Species</span><span class=\"about-stat-val\">Half Human, Half Raccoon</span></div>\n      <div class=\"about-stat-row\"><span class=\"about-stat-icon\">🎂</span><span class=\"about-stat-label\">Debut &amp; Birthday</span><span class=\"about-stat-val\">January 3rd</span></div>\n      <div class=\"about-stat-row\"><span class=\"about-stat-icon\">⋈</span><span class=\"about-stat-label\">Support Mark</span><span class=\"about-stat-val\">⋈🦝 (bow tie &amp; raccoon)</span></div>\n      <div class=\"about-stat-row\"><span class=\"about-stat-icon\">💗</span><span class=\"about-stat-label\">Fan Name</span><span class=\"about-stat-val\">Jumyou (Lifespan)</span></div>\n      <div class=\"about-stat-row\"><span class=\"about-stat-icon\">🌅</span><span class=\"about-stat-label\">Good Morning</span><span class=\"about-stat-val\">Ohami-ta</span></div>\n      <div class=\"about-stat-row\"><span class=\"about-stat-icon\">☀️</span><span class=\"about-stat-label\">Hello</span><span class=\"about-stat-val\">Konmi-ta</span></div>\n      <div class=\"about-stat-row\"><span class=\"about-stat-icon\">🌙</span><span class=\"about-stat-label\">Good Work / See You</span><span class=\"about-stat-val\">Otsumi-ta</span></div>\n   <div class=\"about-stat-row\"><span class=\"about-stat-icon\">💵</span><span class=\"about-stat-label\">Naisu-pa / Naimen</span><span class=\"about-stat-val\">Offering / Kenjou / Jumyou no Kenjou / Subarashiki Jumyou no Kenjou</span></div>   <div class=\"about-stat-row\"><span class=\"about-stat-icon\">🎮</span><span class=\"about-stat-label\">Activities</span><span class=\"about-stat-val\">Chatting, Gaming, Drawing</span></div>\n    </div>\n\n    <div class=\"about-bio-text\">\n      Not Otearai! I'm Mitarai Asobu!<br>When you're happy, spend time with Asobu<br>When you're lonely, spend time with Asobu<br>When you're struggling, spend time with Asobu<br>Your life plan is decided🖤<br>Make absolute use of your lifespan🖤\n    </div>\n\n    <div class=\"about-note-box\">\n      <div class=\"about-note-label\">A request 🤍</div>\n      <div class=\"about-note-text\">Please try to avoid using the phrase \"Naisu-pa\" during my streams!<br>The reason is that it does not carry the weight of your \"lifespan\"!</div>\n    </div>\n\n  </div>\n</div>\n\n<!-- ===== Details Accordion ===== -->\n\n<!-- ===== Intro Video ===== -->\n<div class=\"about-intro-video\">\n  <div class=\"about-intro-video__wrap\">\n    <iframe\n      src=\"https://www.youtube.com/embed/0x1XEsxoS6g\"\n      frameborder=\"0\"\n      allowfullscreen\n      allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\">\n    </iframe>\n  </div>\n</div>\n<div class=\"about-details-section\">\n\n  <div class=\"about-details-section__item\">\n <br> <div class=\"support-sec-head\"><span class=\"support-sec-icon\">✨</span> Dreams I Want to Achieve</div>\n<div class=\"dream-goals\" id=\"dreamGoals\">\n        <!-- rendered by JS from goals.json -->\n      </div>\n\n      <p style=\"margin-top:14px;\">I'll do my best too, so you do your best too, okay?</p>\n     <br>   <div class=\"sp-wish\">\n        <div class=\"support-sec-head\"><span class=\"support-sec-icon\">🎁</span> Wish List</div>\n        <div class=\"sp-wish__item-title\">Soundproof Room</div>\n        <div class=\"sp-wish__body\">\n          <img class=\"sp-wish__icon\" src=\"./mita/happy.png\" alt=\"Mitarai Asobu\">\n          <div class=\"sp-wish__bubble-wrap\">\n            <div class=\"sp-wish__bubble sp-wish__bubble--long\">\n              I've always wanted a <b>Soundproof Room</b>...！<br>\n              I'd be able to stream at night and record songs and ASMR much more easily 🤍<br>\n              I'd be so happy if you could support the crowdfunding!\n            </div>\n            <button class=\"sp-wish__btn\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='crowdfunding'\">🔊 See details ➡</button>\n          </div>\n        </div>\n      </div>\n</div>\n\n\n</div>\n\n<div class=\"support-footer\"><div class=\"support-footer-hearts\">♡ ♡ ♡</div><div class=\"support-footer-name\">Mitarai Asobu</div><div class=\"support-footer-roman\">Mitarai Asobu</div></div>"
  },
