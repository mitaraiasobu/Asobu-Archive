t-img-modal\" class=\"ct-modal\">\n        <div class=\"ct-modal-header\">\n          <div class=\"ct-modal-controls\">\n            <button id=\"ct-zoom-reset\" class=\"ct-btn ct-btn--gray\" style=\"padding:6px 12px;font-size:.82em;\">🔄 100%</button>\n            <input type=\"range\" id=\"ct-zoom-slider\" min=\"50\" max=\"200\" value=\"100\" style=\"width:100px;accent-color:#9333ea;\">\n            <span id=\"ct-zoom-pct\" style=\"color:#fff;font-size:.88em;min-width:2.5rem;\">100%</span>\n          </div>\n          <button id=\"ct-modal-close\" class=\"ct-modal-close\">✕</button>\n        </div>\n        <div id=\"ct-modal-backdrop\" class=\"ct-modal-body\">\n          <img id=\"ct-modal-img\" class=\"ct-modal-img\" src=\"\" alt=\"\">\n        </div>\n      </div>\n    </div>\n      </div><!-- /contestColoringTool -->\n      </div>\n    </div>\n  </details>\n\n  <!-- 第一回イラコン -->\n  <details class=\"ct-archive-card\" open>\n    <summary class=\"ct-archive-summary\">\n      <div class=\"ct-archive-icon\">🏆</div>\n      <div class=\"ct-archive-info\">\n        <div class=\"ct-archive-name\">第一回御手洗遊イラコン</div>\n        <div class=\"ct-archive-period\">2026年1月3日〜3月31日 / 終了</div>\n      </div>\n      <span class=\"ct-archive-arrow\">▼</span>\n    </summary>\n    <div class=\"ct-archive-inner\">\n      <div class=\"inner\" id=\"contest-results\">\n      <div style=\"font-family:'DotGothic16',monospace;font-size:1.1em;font-weight:400;letter-spacing:.04em;margin-bottom:8px;text-align:center;\">🏆 イラストコンテスト 結果発表</div>\n      <div style=\"text-align:center;font-weight:900;font-size:1.05em;margin-bottom:18px;color:#ff79b0;\">受賞おめでとう！</div>\n      <div class=\"ct-promo-grid\" style=\"display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;\">\n        <div style=\"text-align:center;\">\n          <div style=\"font-weight:900;color:#ff79b0;margin-bottom:8px;\">🤍 等身賞</div>\n          <div style=\"font-size:.95em;margin-bottom:10px;\">ミードリ</div>\n          <button class=\"ct-prom