{
  "contest": {
    "title": "",
    "missionTitle": "コンテストに参加して盛り上げよう！",
    "bodyHtml": "<div class=\"support-card support-card--wide\"><div class=\"support-top-stripe\"></div><div class=\"support-inner\">\n\n<style>\n/* ── コンテストページ専用スタイル ── */\n.ct-page-header {\n  text-align: center;\n  padding: 8px 0 32px;\n}\n.ct-page-title {\n  font-family: 'Kaisei Tokumin', serif;\n  font-size: 2em;\n  font-weight: 900;\n  background: linear-gradient(135deg, #ff79b0 0%, #c084fc 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  margin-bottom: 6px;\n}\n.ct-page-sub {\n  font-size: .9em;\n  color: var(--muted);\n  letter-spacing: .06em;\n}\n\n/* ── アクティブコンテストカード ── */\n.ct-active-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  grid-template-rows: auto auto;\n  gap: 20px;\n  margin-bottom: 40px;\n  align-items: start;\n}\n@media(max-width:700px){.ct-active-grid{grid-template-columns:1fr;}}\n\n.ct-contest-card {\n  border: 1px solid rgba(255,121,176,.2);\n  border-radius: 24px;\n  overflow: hidden;\n  background: rgba(255,255,255,.02);\n  transition: transform .2s, box-shadow .2s;\n  cursor: pointer;\n}\n.ct-contest-card:hover {\n  transform: translateY(-3px);\n  box-shadow: 0 8px 32px rgba(255,121,176,.15);\n}\n.ct-contest-card[open] {\n  cursor: default;\n  transform: none;\n}\n.ct-contest-card summary {\n  list-style: none;\n  outline: none;\n}\n.ct-contest-card summary::-webkit-details-marker { display: none; }\n\n.ct-card-thumb {\n  position: relative;\n  overflow: hidden;\n  background: rgba(0,0,0,.2);\n}\n.ct-card-thumb img {\n  width: 100%;\n  height: auto;\n  max-height: 320px;\n  object-fit: contain;\n  object-position: top center;\n  display: block;\n  transition: transform .3s;\n  background: rgba(0,0,0,.2);\n}\n.ct-contest-card:not([open]) .ct-card-thumb img:hover {\n  transform: scale(1.03);\n}\n.ct-card-badge {\n  position: absolute;\n  top: 12px;\n  right: 12px;\n  padding: 4px 12px;\n  border-radius: 999px;\n  font-size: .75em;\n  font-weight: 700;\n  backdrop-filter: blur(6px);\n}\n.ct-card-badge--pink {\n  background: rgba(255,121,176,.85);\n  color: #fff;\n}\n.ct-card-badge--blue {\n  background: rgba(96,165,250,.85);\n  color: #fff;\n}\n.ct-card-badge--teal {\n  background: rgba(45,212,191,.85);\n  color: #fff;\n}\n\n.ct-card-body {\n  padding: 18px 20px 20px;\n}\n.ct-card-title {\n  font-family: 'Kaisei Tokumin', serif;\n  font-size: 1.1em;\n  font-weight: 900;\n  margin-bottom: 4px;\n  color: var(--text);\n}\n.ct-card-deadline {\n  font-size: .78em;\n  color: var(--muted);\n  margin-bottom: 10px;\n}\n.ct-card-desc {\n  font-size: .85em;\n  line-height: 1.7;\n  color: rgba(255,255,255,.75);\n  margin-bottom: 14px;\n}\n.ct-card-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 6px;\n  margin-bottom: 14px;\n}\n.ct-card-tag {\n  padding: 3px 10px;\n  border-radius: 999px;\n  font-size: .75em;\n  font-weight: 700;\n  border: 1px solid rgba(255,121,176,.3);\n  color: var(--accent);\n  background: rgba(255,121,176,.07);\n}\n.ct-card-actions {\n  display: flex;\n  gap: 8px;\n  flex-wrap: wrap;\n}\n.ct-card-btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 8px 16px;\n  border-radius: 999px;\n  font-size: .82em;\n  font-weight: 700;\n  text-decoration: none;\n  transition: opacity .15s, transform .1s;\n  border: none;\n  cursor: pointer;\n}\n.ct-card-btn:hover { opacity: .85; transform: translateY(-1px); }\n.ct-card-btn--primary {\n  background: linear-gradient(135deg, #ff79b0, #c084fc);\n  color: #fff;\n}\n.ct-card-btn--secondary {\n  background: rgba(255,255,255,.08);\n  border: 1px solid rgba(255,255,255,.15);\n  color: var(--text);\n}\n\n/* オニギリスライダー（カード内） */\n.ct-onigiri-slider { position: relative; overflow: hidden; border-radius: 0; }\n.ct-onigiri-track { display: flex; transition: transform .3s ease; }\n.ct-onigiri-slide { min-width: 100%; flex-shrink: 0; }\n.ct-onigiri-slide img { width: 100%; height: auto; max-height: 320px; object-fit: contain; object-position: top; display: block; background: rgba(0,0,0,.2); }\n.ct-onigiri-nav {\n  position: absolute; top: 50%; transform: translateY(-50%);\n  width: 28px; height: 28px; border-radius: 50%;\n  background: rgba(0,0,0,.6); border: 1px solid rgba(255,255,255,.3);\n  color: #fff; cursor: pointer; font-size: 14px;\n  display: flex; align-items: center; justify-content: center;\n  z-index: 5;\n}\n.ct-onigiri-nav--prev { left: 8px; }\n.ct-onigiri-nav--next { right: 8px; }\n.ct-onigiri-dots { display: flex; justify-content: center; gap: 6px; padding: 10px 0 0; }\n.ct-onigiri-dot {\n  width: 6px; height: 6px; border-radius: 50%;\n  background: var(--accent); border: none; cursor: pointer; padding: 0;\n  opacity: .3; transition: opacity .2s;\n}\n.ct-onigiri-dot.active { opacity: 1; }\n\n/* ── 過去のコンテスト ── */\n.ct-archive-section { margin-top: 48px; }\n.ct-archive-title {\n  font-size: 1.4em;\n  font-family: 'Kaisei Tokumin', serif;\n  font-weight: 900;\n  color: var(--accent);\n  text-align: center;\n  margin-bottom: 20px;\n  padding-bottom: 12px;\n  border-bottom: 1px solid rgba(255,121,176,.2);\n}\n.ct-archive-card {\n  border: 1px solid rgba(255,255,255,.08);\n  border-radius: 16px;\n  margin-bottom: 12px;\n  overflow: hidden;\n  background: rgba(255,255,255,.02);\n}\n.ct-archive-summary {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  padding: 14px 18px;\n  cursor: pointer;\n  user-select: none;\n}\n.ct-archive-summary { list-style: none; }\n.ct-archive-summary::-webkit-details-marker { display: none; }\n.ct-archive-summary::marker { display: none; }\n.ct-archive-icon {\n  width: 44px; height: 44px; border-radius: 12px;\n  background: rgba(255,255,255,.06);\n  display: flex; align-items: center; justify-content: center;\n  font-size: 20px; flex-shrink: 0;\n}\n.ct-archive-info { flex: 1; }\n.ct-archive-name { font-weight: 700; font-size: .95em; }\n.ct-archive-period { font-size: .78em; color: var(--muted); margin-top: 2px; }\n.ct-archive-arrow {\n  font-size: .8em; color: var(--muted);\n  transition: transform .2s;\n}\ndetails.ct-archive-card[open] .ct-archive-arrow { transform: rotate(180deg); }\n.ct-archive-inner { padding: 0 18px 20px; }\n\n/* 受賞作品グリッド */\n.ct-awards-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 14px;\n  margin-bottom: 16px;\n}\n@media(max-width:500px){.ct-awards-grid{grid-template-columns:1fr;}}\n.ct-award-item { text-align: center; }\n.ct-award-label {\n  display: inline-block;\n  padding: 3px 12px;\n  border-radius: 999px;\n  font-size: .75em;\n  font-weight: 700;\n  margin-bottom: 6px;\n}\n.ct-award-label--gold { background: rgba(255,200,50,.15); color: #fde68a; border: 1px solid rgba(255,200,50,.3); }\n.ct-award-label--silver { background: rgba(180,180,220,.1); color: #c0c0e0; border: 1px solid rgba(180,180,220,.25); }\n.ct-award-name { font-size: .85em; font-weight: 700; margin-bottom: 8px; }\n.ct-award-img {\n  width: 100%; max-width: 280px;\n  border-radius: 12px;\n  box-shadow: 0 4px 12px rgba(0,0,0,.4);\n  cursor: pointer;\n  transition: transform .2s;\n}\n.ct-award-img:hover { transform: scale(1.02); }\n\n/* アニメーション */\n@keyframes ct-fade-up {\n  from { opacity: 0; transform: translateY(16px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n.ct-contest-card {\n  animation: ct-fade-up .4s ease both;\n}\n.ct-contest-card:nth-child(2) { animation-delay: .08s; }\n.ct-contest-card:nth-child(3) { animation-delay: .16s; }\n</style>\n\n<!-- ヘッダー -->\n<div class=\"ct-page-header\">\n  <div class=\"ct-page-title\">コンテスト</div>\n  <div class=\"ct-page-sub\">コンテストに参加して盛り上げよう！</div>\n</div>\n\n<!-- ===== アクティブコンテスト ===== -->\n<div class=\"ct-active-grid\">\n\n  <!-- 学生服イラストコンテスト -->\n  <div class=\"ct-contest-card\">\n      <div class=\"ct-card-thumb\">\n        <img src=\"./assets/学生服イラストコンテスト.png\" alt=\"学生服イラストコンテスト\" onclick=\"openLightbox('./assets/学生服イラストコンテスト.png')\" style=\"cursor:zoom-in;\" />\n        <span class=\"ct-card-badge ct-card-badge--pink\">📅 5/31締切</span>\n      </div>\n    <div class=\"ct-card-body\">\n      <div class=\"ct-card-title\">👗 学生服イラストコンテスト</div>\n      <div class=\"ct-card-deadline\">締切：2026年5月31日</div>\n      <div class=\"ct-card-desc\">御手洗遊を学生服衣装で描いてみよう！<br>コンテスト終了後もタグを使ってOK。<br>※学生服衣装を必ず含めてください。</div>\n      <div class=\"ct-card-tags\">\n        <span class=\"ct-card-tag\">⭕ 学生服のみ</span>\n        <span class=\"ct-card-tag\">⭕ 学生服＋デフォルト</span>\n        <span class=\"ct-card-tag\">❌ デフォルトのみ</span>\n      </div>\n      <div class=\"ct-card-actions\">\n        <a href=\"https://x.com/hashtag/%E5%BE%A1%E6%89%8B%E6%B4%97%E9%81%8A%E5%AD%A6%E7%94%9F%E6%9C%8D?src=hashtag_click&f=live\" target=\"_blank\" rel=\"noopener\" class=\"ct-card-btn ct-card-btn--primary\">👀 みんなの作品を見る</a>\n      </div>\n    </div>\n  </div>\n\n  <!-- オニギリラクーンコンテスト -->\n  <div class=\"ct-contest-card\">\n      <div class=\"ct-card-thumb\">\n        <div class=\"ct-onigiri-slider\">\n          <button class=\"ct-onigiri-nav ct-onigiri-nav--prev\" onclick=\"onigiriGo(Math.max(0,(window._onigiriIndex||0)-1));event.stopPropagation()\">‹</button>\n          <button class=\"ct-onigiri-nav ct-onigiri-nav--next\" onclick=\"onigiriGo(Math.min(1,(window._onigiriIndex||0)+1));event.stopPropagation()\">›</button>\n          <div class=\"ct-onigiri-track\" id=\"onigiriTrack\">\n            <div class=\"ct-onigiri-slide\"><img src=\"./assets/オニギリラクーンコンテスト.png\" alt=\"オニギリラクーン1\" onclick=\"openLightbox('./assets/オニギリラクーンコンテスト.png')\" style=\"cursor:zoom-in;\" /></div>\n            <div class=\"ct-onigiri-slide\"><img src=\"./assets/オニギリラクーンコンテスト2.png\" alt=\"オニギリラクーン2\" onclick=\"openLightbox('./assets/オニギリラクーンコンテスト2.png')\" style=\"cursor:zoom-in;\" /></div>\n          </div>\n        </div>\n        <span class=\"ct-card-badge ct-card-badge--blue\">∞ 常時応募可能</span>\n      </div>\n      <div class=\"ct-onigiri-dots\" style=\"background:rgba(0,0,0,.2);padding:8px 0;\">\n        <button class=\"ct-onigiri-dot active\" onclick=\"onigiriGo(0);event.stopPropagation()\"></button>\n        <button class=\"ct-onigiri-dot\" onclick=\"onigiriGo(1);event.stopPropagation()\"></button>\n      </div>\n    <div class=\"ct-card-body\">\n      <div class=\"ct-card-title\">🍙 オニギリラクーンコンテスト</div>\n      <div class=\"ct-card-deadline\">締切：未定（常時応募OK！）</div>\n      <div class=\"ct-card-desc\">帽子をかぶせたり持ち物を持たせたりして、個性豊かなオニギリラクーンをデザインしよう！好きな方の画像を使って応募してね。1人何枚でも！</div>\n      <div class=\"ct-card-actions\">\n        <a href=\"https://x.com/hashtag/%E3%82%AA%E3%83%8B%E3%82%AE%E3%83%AA%E3%83%A9%E3%82%AF%E3%83%BC%E3%83%B3?src=hashtag_click&f=live\" target=\"_blank\" rel=\"noopener\" class=\"ct-card-btn ct-card-btn--primary\">👀 みんなの作品を見る</a>\n        <a href=\"./assets/オニギリラクーンコンテスト.png\" download class=\"ct-card-btn ct-card-btn--secondary\">⬇ 画像DL①</a>\n        <a href=\"./assets/オニギリラクーンコンテスト2.png\" download class=\"ct-card-btn ct-card-btn--secondary\">⬇ 画像DL②</a>\n      </div>\n    </div>\n  </div>\n\n  <!-- 切り抜き動画コンテスト（1カラム幅） -->\n  <div class=\"ct-contest-card\">\n      <div class=\"ct-card-thumb\">\n        <img src=\"./assets/切り抜き動画コンテスト.png\" alt=\"切り抜き動画コンテスト\" onclick=\"openLightbox('./assets/切り抜き動画コンテスト.png')\" style=\"cursor:zoom-in;\" />\n        <span class=\"ct-card-badge ct-card-badge--teal\">∞ 常時応募</span>\n      </div>\n    <div class=\"ct-card-body\">\n      <div class=\"ct-card-title\">✂️ 切り抜き動画コンテスト</div>\n      <div class=\"ct-card-deadline\">常時応募可能</div>\n      <div class=\"ct-card-desc\">完成した動画はXのDMもしくはメールに送ってください！応募期限は廃止しました、いつでも応募OK！</div>\n    </div>\n  </div>\n\n</div>\n\n<!-- ===== 過去のコンテスト ===== -->\n<div class=\"ct-archive-section\">\n  <div class=\"ct-archive-title\">📂 過去のコンテスト</div>\n\n  <!-- 塗り絵コンテスト -->\n  <details class=\"ct-archive-card\" open>\n    <summary class=\"ct-archive-summary\">\n      <div class=\"ct-archive-icon\">🎨</div>\n      <div class=\"ct-archive-info\">\n        <div class=\"ct-archive-name\">新衣装塗り絵コンテスト</div>\n        <div class=\"ct-archive-period\">2026年4月 / 終了</div>\n      </div>\n      <span class=\"ct-archive-arrow\">▼</span>\n    </summary>\n    <div class=\"ct-archive-inner\">\n      <div style=\"font-weight:700;color:var(--accent);margin-bottom:14px;font-size:.9em;\">🏆 受賞作品</div>\n      <div class=\"ct-awards-grid\">\n        <div class=\"ct-award-item\">\n          <div><span class=\"ct-award-label ct-award-label--gold\">✨ 最優秀賞</span></div>\n          <div class=\"ct-award-name\">ミードリ</div>\n          <img src=\"./assets/学生服最優秀賞.png\" alt=\"最優秀賞\" class=\"ct-award-img\" onclick=\"openLightbox('./assets/学生服最優秀賞.png')\" />\n        </div>\n        <div class=\"ct-award-item\">\n          <div><span class=\"ct-award-label ct-award-label--silver\">⭐ 特別賞</span></div>\n          <div class=\"ct-award-name\">しののん</div>\n          <img src=\"./assets/学生服特別賞.png\" alt=\"特別賞\" class=\"ct-award-img\" onclick=\"openLightbox('./assets/学生服特別賞.png')\" />\n        </div>\n      </div>\n      <button onclick=\"toggleColoringTool()\" class=\"ct-card-btn ct-card-btn--primary\" style=\"margin-top:4px;\">🎨 塗ってみる</button>\n      <div id=\"contestColoringTool\" style=\"display:none;margin-top:16px;\">\n        <div style=\"padding:10px 14px;border-radius:12px;background:rgba(255,200,50,.08);border:1px solid rgba(255,200,50,.25);color:#fde68a;font-size:.82em;font-weight:700;margin-bottom:14px;\">⚠️ コンテスト応募期間は終了しているため入賞することはできません。</div>\n        <div class=\"inner\" id=\"contest-root\">\n      <h4 style=\"color:var(--accent);margin-bottom:16px;\">🏆 受賞作品</h4>\n      <div style=\"margin-bottom:20px;\">\n        <p style=\"font-weight:700;margin-bottom:8px;\">✨ 最優秀賞 - ミードリ</p>\n        <img src=\"./assets/学生服最優秀賞.png\" alt=\"最優秀賞\" style=\"cursor:pointer;cursor:pointer;width:100%;max-width:400px;border-radius:12px;box-shadow:0 4px 12px rgba(0,0,0,.3);\" onclick=\"openLightbox('./assets/学生服最優秀賞.png')\" />\n      </div>\n      <div style=\"margin-bottom:24px;\">\n        <p style=\"font-weight:700;margin-bottom:8px;\">⭐ 特別賞 - しののん</p>\n        <img src=\"./assets/学生服特別賞.png\" alt=\"特別賞\" style=\"cursor:pointer;cursor:pointer;width:100%;max-width:400px;border-radius:12px;box-shadow:0 4px 12px rgba(0,0,0,.3);\" onclick=\"openLightbox('./assets/学生服特別賞.png')\" />\n      </div>\n      <button onclick=\"toggleColoringTool()\" style=\"padding:12px 24px;background:linear-gradient(135deg,#ff79b0,#ffaadd);color:#fff;border:none;border-radius:999px;font-weight:700;cursor:pointer;margin-bottom:16px;\">🎨 塗ってみる</button>\n      <div id=\"contestColoringTool\" style=\"display:none;\">\n      <div style=\"padding:12px 16px;border-radius:12px;background:rgba(255,200,50,.08);border:1px solid rgba(255,200,50,.25);color:#fde68a;font-weight:700;margin-bottom:14px;\">⚠️ コンテスト応募期間は終了しているため入賞することはできません。</div>\n      <style>\n      #contest-root{width:100%;font-family:system-ui,-apple-system,'Segoe UI',Roboto,'Noto Sans JP',sans-serif;}\n      .ct-dlbar{position:relative;margin-bottom:18px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:16px 52px 16px 18px;overflow:visible;}\n      .ct-dlbar-close{position:absolute;top:10px;right:10px;z-index:10;width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:var(--text);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;}\n      .ct-dlbtns{display:flex;gap:10px;flex-wrap:wrap;}\n      .ct-dlbtn{flex:1;min-width:160px;display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:13px 18px;border-radius:12px;font-weight:700;font-size:.95em;text-decoration:none;transition:opacity .15s,transform .1s;}\n      .ct-dlbtn:hover{opacity:.85;transform:translateY(-1px);}\n      .ct-dlbtn--purple{background:rgba(147,51,234,.85);color:#fff;}\n      .ct-dlbtn--dark{background:#1f1f25;border:1px solid rgba(255,255,255,.15);color:var(--text);}\n      .ct-dlnote{margin-top:10px;font-size:.82em;color:var(--muted);}\n      .ct-status-yellow{background:rgba(234,179,8,.1);border-left:4px solid #eab308;padding:10px 14px;border-radius:0 10px 10px 0;margin-bottom:14px;color:#fde68a;}\n      .ct-status-red{background:rgba(239,68,68,.1);border-left:4px solid #ef4444;padding:10px 14px;border-radius:0 10px 10px 0;margin-bottom:14px;color:#fca5a5;}\n      .ct-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px;}\n      .ct-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.10);border-radius:14px;padding:18px;}\n      .ct-card--canvas{border-color:rgba(147,51,234,.3);}\n      .ct-canvas-wrap{border:3px solid rgba(147,51,234,.3);border-radius:10px;overflow:hidden;background:#fff;margin-bottom:14px;}\n      .ct-canvas-wrap canvas{width:100%;height:auto;display:block;}\n      .ct-hsv-picker{position:relative;width:100%;aspect-ratio:16/9;border-radius:8px;overflow:hidden;cursor:crosshair;margin-bottom:8px;min-height:160px;}\n      .ct-hsv-sat{position:absolute;inset:0;background:linear-gradient(to right,#fff,transparent);}\n      .ct-hsv-bri{position:absolute;inset:0;background:linear-gradient(to bottom,transparent,#000);}\n      .ct-hsv-cursor-dot{position:absolute;width:14px;height:14px;border-radius:50%;border:2.5px solid #fff;box-shadow:0 0 0 1.5px rgba(0,0,0,.8);pointer-events:none;transform:translate(-50%,-50%);top:0%;left:100%;}\n      .ct-canvas-btns{display:flex;flex-direction:column;gap:8px;}\n      .ct-canvas-row{display:flex;gap:8px;align-items:stretch;flex-wrap:wrap;}\n      .ct-btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:11px 16px;border-radius:10px;font-weight:700;font-size:.88em;cursor:pointer;border:none;transition:opacity .15s,transform .1s;}\n      .ct-btn:hover{opacity:.85;transform:translateY(-1px);}\n      .ct-btn--pink{background:rgba(236,72,153,.8);color:#fff;}\n      .ct-btn--green{background:rgba(22,163,74,.8);color:#fff;}\n      .ct-btn--blue{background:rgba(59,130,246,.8);color:#fff;}\n      .ct-btn--gray{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,