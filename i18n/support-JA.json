    "bodyHtml": "<div class=\"support-card support-card--wide\">\n  <div class=\"support-top-stripe\"></div>\n  <div class=\"support-inner\">\n\n    <!-- ── Header ── -->\n    <div class=\"support-header\">\n      <div class=\"support-main-title\">献上のススメ<br></div><div class=\"support-sub-title\">上から順に、めざせ完全制覇！</div> <div class=\"support-deco-line\">♡ ♡ ♡</div><span class=\"support-accent\">寿命なら当然...だよね？</span>\n      \n    </div>\n\n    <!-- ── Spread / Tech Section ── -->\n    <div class=\"support-accordion-wrap open\" id=\"acc-spread\">\n      <div class=\"support-accordion-header\" onclick=\"toggleAcc('acc-spread')\">\n        <div class=\"support-sec-head\"><span class=\"support-sec-icon\">⋈</span> すぐにできる拡散や技術で献上</div>\n        <span class=\"support-accordion-arrow\">▼</span>\n      </div>\n      <div class=\"support-accordion-body\">\n\n        <!-- ── Clip Request Section ── -->\n        <div class=\"support-clip-request\">\n          <div class=\"support-clip-request__img-wrap\">\n            <img src=\"./assets/切り抜きリクエスト.png\" alt=\"切り抜きリクエスト\" class=\"support-clip-request__img\" />\n          </div>\n          <div class=\"support-clip-request__body\">\n            <div class=\"support-clip-request__title\">切り抜き動画にしてほしいシーンを教えてください！</div>\n            <div class=\"support-clip-request__desc\">お気に入りのシーンの生配信のリンクとタイムスタンプ（1:20:14など）を送ると、切り抜き動画が作成されるかも！１人でシーンを探すのはとても大変なので協力していただけると嬉しいです！</div>\n            <a class=\"support-clip-request__btn\" href=\"https://marshmallow-qa.com/g2t47f2przg3nzd\" target=\"_blank\" rel=\"noopener\">🎬 切り抜きシーンをリクエストする</a>\n          </div>\n        </div>\n\n        <div class=\"support-spread-list\">\n\n      <div class=\"support-spread-item\">\n        <div class=\"support-pink-dot\"></div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">高評価＆共有コピー＆ハイプ</div>\n          <div class=\"support-inote\">YouTubeの動画や生配信、Xの投稿を拡散して欲しいです🤍<br>共有ボタン→コピーを押すとオススメ度が上がるよ！</div>\n        </div>\n      </div>\n\n      <div class=\"support-spread-item\">\n        <div class=\"support-pink-dot\"></div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">コンテストに参加する</div>\n          <div class=\"support-inote\">塗り絵やイラストのコンテストに参加して、皆で盛り上がろう！</div>\n        </div>\n        <a class=\"support-item-arrow\" href=\"#contest\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='contest'\">➡</a>\n      </div>\n\n      <div class=\"support-spread-item\">\n        <div class=\"support-pink-dot\"></div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">切り抜き動画を作る</div>\n          <div class=\"support-inote\">作った動画を私に送ってね！私のチャンネルで投稿します！</div>\n        </div>\n      </div>\n\n\n      </div><!-- /spread-list -->\n      </div><!-- /accordion-body -->\n    </div><!-- /acc-spread -->\n\n    <!-- ── Priority list ── -->\n    <div class=\"support-accordion-wrap open\" id=\"acc-money\">\n      <div class=\"support-accordion-header\" onclick=\"toggleAcc('acc-money')\">\n        <div class=\"support-sec-head\"><span class=\"support-sec-icon\">⋈</span> おとな向けの献上♡</div>\n        <span class=\"support-accordion-arrow\">▼</span>\n      </div>\n      <div class=\"support-accordion-body\">\n        <div style=\"font-size:1.4em;font-weight:900;letter-spacing:.02em;padding:10px 16px 10px 20px;color:#ffffff;border-left:3px solid #ff79b0;margin:0 0 12px 0;\">遊の嬉しさランキング</div>\n        <div class=\"support-list\">\n      <div class=\"support-item-row\">\n      <div class=\"support-item support-top\">\n        <div class=\"support-nbubble\">1</div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">メンバーシップ</div>\n          <div class=\"support-inote\">毎月継続してもらえるのが一番嬉しい！限定グッズプレゼントもあるよ～</div>\n        </div>\n        <div class=\"support-iright\">月 ¥490～</div>\n      </div>\n      <a class=\"support-item-arrow\" href=\"#membership\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='membership'\">➡</a>\n      </div>\n      <div class=\"support-item-row\">\n      <div class=\"support-item\">\n        <div class=\"support-nbubble\">2</div>\n        <div class=\"support-ibody\">\n          <div class=\"support-iname\">グッズ購入</div>\n          <div class=\"support-inote\">画面の中だけじゃ足りないでしょ</div>\n        </div>\n        <div class=\"support-iright\">¥750〜</div>\n      </div>\n      <a class=\"support-item-arrow\" href=\"#goods\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='goods'\">➡</a>\n      </div>\n\n        <div class=\"support-item-row\">\n        <div class=\"support-item\" style=\"flex-direction:column;align-items:flex-start;\">\n          <div style=\"display:flex;align-items:center;gap:10px;width:100%;\">\n            <div class=\"support-nbubble\">3</div>\n            <div class=\"support-ibody\">\n              <div class=\"support-iname\">寿命献上（PayPal）</div>\n              <div class=\"support-inote\">やっぱ現ナマだよね！</div>\n            </div>\n            <a class=\"support-item-arrow\" href=\"#crowdfunding\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='crowdfunding'\">➡</a>\n          </div>\n          <div class=\"paypal-standalone-wrap paypal-standalone-wrap--wide\" style=\"width:100%;margin:12px 0 0;\">\n            <div id=\"paypal-container-RK2RCL2TGJWVU\"></div>\n          </div>\n        </div>\n        </div>\n        <div class=\"support-item-row\">\n        <div class=\"support-item\">\n          <div class=\"support-nbubble\">4</div>\n          <div class=\"support-ibody\">\n            <div class=\"support-iname\">スーパーチャット/メンバーギフト</div>\n            <div class=\"support-inote\">ライブ中にいつでもちょうだい🖤一日千円マスト！</div>\n          </div>\n          <span class=\"support-iright\">¥100〜</span>\n        </div>\n        <a class=\"support-item-arrow\" href=\"https://www.youtube.com/@MitaraiAsobu\" target=\"_blank\" rel=\"noopener\">➡</a>\n        </div>\n      </div>\n    <div class=\"sp-wish\" style=\"margin:24px 0;\">\n      <div class=\"sp-wish__body\">\n        <img class=\"sp-wish__icon\" src=\"./mita/money.png\" alt=\"御手洗 遊\">\n        <div class=\"sp-wish__bubble-wrap\">\n          <div class=\"sp-wish__bubble\">献上献上～！</div>\n        </div>\n      </div>\n    </div>\n\n\n\n    <!-- ── Crowdfunding Note ── -->\n    <div class=\"support-sec-head\"><span class=\"support-sec-icon\">⋈</span> クラウドファンディングについて</div>\n\n    <div class=\"support-goods-box\">\n      <div class=\"support-goods-icon\">💰</div>\n      <div class=\"support-goods-body\">\n        <div class=\"support-goods-title\">どの献上でもクラウドファンディングの金額に加算されます！詳しくはクラファンページをご覧ください。</div>\n <a class=\"support-clip-request__btn\" href=\"#crowdfunding\" onclick=\"event.preventDefault();window.scrollTo(0,0);location.hash='crowdfunding'\" style=\"margin-top:14px;display:inline-flex;\">🎗 クラファンページを見る</a>\n      </div>\n    </div>\n\n      </div><!-- /accordion-body -->\n    </div><!-- /acc-money -->\n\n    <!-- ── Footer ── -->\n    <div class=\"support-footer\">\n      <div class=\"support-footer-hearts\">♡ ♡ ♡</div>\n      <div class=\"support-footer-msg\">応援してくれるあなたともっと楽しい日々を</div>\n      <div class=\"support-footer-name\">御手洗 遊</div>\n      <div class=\"support-footer-roman\">Mitarai Asobu</div>\n    </div>\n\n  </div>\n</div>"
  }
